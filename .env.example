SERVICE_NAME=bosgenesis-mop-execution-agent
ENVIRONMENT=dev
API_HOST=0.0.0.0
API_PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/mop_execution
REDIS_URL=redis://localhost:6379/0
CLICKHOUSE_DSN=http://localhost:8123
ARTIFACT_ROOT_PATH=./.data/mop-execution
K8S_INSPECTOR_MCP_ENDPOINT=http://localhost:8011
K8S_INSPECTOR_API_KEY=
NAMESPACE_TWIN_LIVE_COLLECTION_ENABLED=true
NAMESPACE_TWIN_HELM_INSTALLED_RELEASES_ONLY=true
NAMESPACE_TWIN_HELM_IGNORE_PREFIXES=bosgenesis-
# Platform-managed ConfigMaps remain in generated bundles for now, but Twin planning ignores them.
NAMESPACE_TWIN_CONFIGMAP_EXCLUDE_NAMES=kube-root-ca.crt
NAMESPACE_TWIN_CONFIGMAP_EXCLUDE_PREFIXES=istio-
NAMESPACE_TWIN_PVC_RISK_ENABLED=false
HELM_MANAGER_MCP_ENDPOINT=http://localhost:8012
K8S_DATA_INGESTION_MCP_ENDPOINT=http://localhost:8013
RELEASE_NOTE_AGENT_ENDPOINT=http://localhost:8014
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SIGNOZ_ENDPOINT=http://localhost:3301
LANGFUSE_ENABLED=false
